# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars should NEVER be committed to version control (add it to .gitignore).

aws_region   = "ap-south-1"
project_name = "multitier-app"
environment  = "dev"

# Networking
vpc_cidr                 = "10.0.0.0/16"
public_subnet_cidr       = "10.0.1.0/24"
private_app_subnet_cidr  = "10.0.2.0/24"
private_db_subnet_cidr   = "10.0.3.0/24"
private_db_subnet_cidr_2 = "10.0.4.0/24"
availability_zones       = ["ap-south-1a", "ap-south-1b"]

# EC2
key_name          = "my-ec2-keypair"      # must already exist in your AWS account
web_instance_type = "t2.micro"
app_instance_type = "t2.micro"
ssh_allowed_cidr  = "0.0.0.0/0"           # replace with your IP, e.g. "203.0.113.10/32"

# RDS
create_rds           = true
db_engine            = "mysql"
db_engine_version    = "8.0"
db_instance_class    = "db.t3.micro"
db_name              = "appdb"
db_username          = "admin"
db_password          = "ChangeMe123!"     # use a strong password / Secrets Manager in real deployments
db_allocated_storage = 20

# S3 (leave blank to auto-generate a unique name)
s3_bucket_name = ""
